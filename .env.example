# Variables d'environnement — Homely Budget Foyer
# Copier ce fichier en .env (ne jamais committer .env)

# ── Base de données ──────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/homely
DB_USER=homely
DB_PASSWORD=change_me_in_production

# ── JWT ──────────────────────────────────────────────────
# Clé HMAC-SHA256 ≥ 256 bits — générer avec : openssl rand -hex 32
JWT_SECRET=change_me_in_production_must_be_at_least_256_bits_long

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:4200
